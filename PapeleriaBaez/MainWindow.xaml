<Window x:Class="PapeleriaBaez.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PapeleriaBaez"
        mc:Ignorable="d"
        Title="Papelería Báez" Height="700" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- Menú Lateral -->
        <StackPanel Grid.Column="0" Background="#2C3E50">

            <TextBlock Text="Papelería Báez"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="15"/>

            <Button Content="🏠 Inicio" 
                    Margin="10"
                    Click="BtnDashboard_Click"/>
            
            <Button Content="🛒 Punto de Venta"
                    Margin="10"
                    Click="BtnVentas_Click"/>
            
            <Button Content="📦 Productos"
                    Margin="10"
                    Click="BtnProductos_Click"/>
            
            <Button Content="📂 Categorías"
                    Margin="10"
                    Click="BtnCategorias_Click"/>

            <Button Content="📥 Compras"
                    Margin="10"
                    Click="BtnCompras_Click"/>

            <Button Content="📋 Inventario"
                    Margin="10"
                    Click="BtnInventario_Click"/>

            <Button Content="🎒 Canjes"
                    Margin="10"
                    Click="BtnCanjes_Click"/>

            <Button Content="💰 Deudas"
                    Margin="10"
                    Click="BtnDeudas_Click"/>

            <Button Content="📊 Reportes"
                    Margin="10"
                    Click="BtnReportes_Click"/>
            
            <Button Content="⚙️ Configuración" 
                    Margin="10"
                    Click="BtnConfiguracion_Click"/>
            
        </StackPanel>
        
        <!-- Área Principal -->
        <Grid Grid.Column="1">

            <Frame x:Name="MainFrame" Margin="0,-5,0,5"/>

        </Grid>

    </Grid>
</Window>
