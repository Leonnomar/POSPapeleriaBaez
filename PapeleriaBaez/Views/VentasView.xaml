<UserControl x:Class="PapeleriaBaez.Views.VentasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PapeleriaBaez.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Título -->
            <RowDefinition Height="Auto"/>  <!-- Buscar -->
            <RowDefinition Height="Auto"/>  <!-- Resultados -->
            <RowDefinition Height="*"/>     <!-- Carrito -->
            <RowDefinition Height="Auto"/>  <!-- Totales -->
            <RowDefinition Height="Auto"/>  <!-- Botones -->
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="🛒 Punto de Venta"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- Búsqueda -->
        <Grid Grid.Row="1"
            Margin="0,0,0,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Código:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="txtBuscar"
                     Grid.Column="1"
                     Height="30"
                     Margin="5"
                     KeyDown="txtBuscar_KeyDown"
                     TextChanged="txtBuscar_TextChanged"/>

            <Button x:Name="btnBuscar"
                    Grid.Column="2"
                    Content="Buscar"
                    Margin="5"
                    Width="100"/>

        </Grid>

        <Border x:Name="panelResultados"
                Grid.Row="2"
                Width="500"
                HorizontalAlignment="Left"
                Margin="105,0,0,5"
                Background="White"
                BorderBrush="#BFBFBF"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="Collapsed"
                Panel.ZIndex="100">

            <ListBox x:Name="lstResultados"
                             BorderThickness="0"
                             MaxHeight="250"
                             MouseDoubleClick="lstResultados_MouseDoubleClick"
                             KeyDown="lstResultados_KeyDown">

                <ListBox.ItemTemplate>

                    <DataTemplate>

                        <Border BorderBrush="#EEEEEE"
                                    BorderThickness="0,0,0,1"
                                    Padding="8">

                            <StackPanel>

                                <TextBlock FontWeight="Bold"
                                               FontSize="14"
                                               Text="{Binding Codigo}"/>

                                <TextBlock FontSize="15"
                                               Margin="0,2"
                                               Text="{Binding Nombre}"/>

                                <DockPanel Margin="0,5,0,0">

                                    <TextBlock Text="{Binding PrecioVenta,
                                                  StringFormat=Precio\: {0:C}}"
                                                   FontWeight="SemiBold"/>

                                    <TextBlock DockPanel.Dock="Right">

                                        <TextBlock.Style>

                                            <Style TargetType="TextBlock">

                                                <Setter Property="Text"
                                                            Value="{Binding Stock,
                                                            StringFormat=Stock\: {0}}"/>

                                                <Setter Property="Foreground"
                                                            Value="Green"/>

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Stock}"
                                                                     Value="0">

                                                        <Setter Property="Foreground"
                                                                    Value="Red"/>

                                                    </DataTrigger>

                                                </Style.Triggers>

                                            </Style>

                                        </TextBlock.Style>

                                    </TextBlock>

                                </DockPanel>

                            </StackPanel>
                        </Border>

                    </DataTemplate>

                </ListBox.ItemTemplate>

            </ListBox>

        </Border>

        <!-- Carrito -->
        <DataGrid x:Name="dgVenta"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Código"
                                    Binding="{Binding Codigo}"
                                    Width="120"/>

                <DataGridTextColumn Header="Producto"
                                    Binding="{Binding Nombre}"
                                    Width="*"/>

                <DataGridTextColumn Header="Cantidad"
                                    Binding="{Binding Cantidad}"
                                    Width="90"/>

                <DataGridTextColumn Header="Precio"
                                    Binding="{Binding Precio}"
                                    Width="100"/>

                <DataGridTextColumn Header="Importe"
                                    Binding="{Binding Importe}"
                                    Width="120"/>
                
            </DataGrid.Columns>
            
        </DataGrid>

        <!-- Totales -->
        <StackPanel Grid.Row="4"
                    HorizontalAlignment="Right"
                    Margin="0,15">

            <TextBlock x:Name="lblSubtotal"
                       Text="Subtotal: $0.00"
                       FontSize="18"/>

            <TextBlock x:Name="lblDescuento"
                       Text="Descuento: $0.00"
                       FontSize="18"/>

            <TextBlock x:Name="lblTotal"
                       Text="TOTAL: $0.00"
                       FontSize="24"
                       FontWeight="Bold"/>

        </StackPanel>

        <!-- Botones -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20">

            <Button Content="💰 Cobrar"
                    Width="140"
                    Height="45"
                    Margin="10"
                    Click="btnCobrar_Click"/>

            <Button Content="❌ Cancelar"
                    Width="140"
                    Height="45"
                    Margin="10"/>

            <Button Content="🗑 Eliminar"
                    Width="140"
                    Height="45"
                    Margin="10"/>

        </StackPanel>
        
    </Grid>
    
</UserControl>
