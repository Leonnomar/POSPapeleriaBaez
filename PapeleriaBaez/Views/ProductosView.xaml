<UserControl x:Class="PapeleriaBaez.Views.ProductosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Productos"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Código:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="txtCodigo"
                     Grid.Column="1"
                     Margin="5"
                     IsReadOnly="True"/>

            <TextBlock Grid.Column="2"
                       Text="Nombre:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="txtNombre"
                     Grid.Column="3"
                     Margin="5"/>

            <TextBlock Grid.Row="1"
                       Text="Costo:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="txtCosto"
                     PreviewTextInput="Decimal_PreviewTextInput"
                     Grid.Row="1"
                     Grid.Column="1"
                     Margin="5"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="2"
                       Text="Precio:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="txtPrecio"
                     PreviewTextInput="Decimal_PreviewTextInput"
                     Grid.Row="1"
                     Grid.Column="3"
                     Margin="5"/>

            <TextBlock Grid.Row="2"
                       Text="Stock:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="txtStock"
                     PreviewTextInput="Entero_PreviewTextInput"
                     Grid.Row="2"
                     Grid.Column="1"
                     Margin="5"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="2"
                       Text="Stock Mínimo:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="txtStockMinimo"
                     PreviewTextInput="Entero_PreviewTextInput"
                     Grid.Row="2"
                     Grid.Column="3"
                     Margin="5"/>

            <TextBlock Grid.Row="3"
                       Text="Categoría:"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="cmbCategorias"
                      Grid.Row="3"
                      Grid.Column="1"
                      Margin="5"
                      DisplayMemberPath="Nombre"
                      SelectionChanged="cmbCategorias_SelectionChanged"/>
            
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Vertical">

            <StackPanel Orientation="Horizontal"
                        Margin="0,20,0,20">

                <Button Content="Guardar"
                        Width="100"
                        Margin="5"
                        Click="BtnGuardar_Click"/>

                <Button Content="Actualizar"
                        Width="100"
                        Margin="5"
                        Click="BtnActualizar_Click"/>

                <Button Content="Limpiar"
                        Width="100"
                        Margin="5"
                        Click="BtnLimpiar_Click"/>

                <Button Content="Eliminar"
                        Width="100"
                        Margin="5"
                        Click="BtnEliminar_Click"/>
                
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="0,10,0,10">

                <TextBlock Text="Buscar:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <TextBox x:Name="txtBuscar"
                         Width="250"
                         TextChanged="txtBuscar_TextChanged"/>
                
            </StackPanel>

            <DataGrid x:Name="dgProductos"
                      Height="300"
                      AutoGenerateColumns="False"
                      SelectionChanged="dgProductos_SelectionChanged">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding Codigo}" />

                    <DataGridTextColumn Header="Nombre"
                                        Binding="{Binding Nombre}" />

                    <DataGridTextColumn Header="Costo"
                                        Binding="{Binding Costo}" />

                    <DataGridTextColumn Header="Precio"
                                        Binding="{Binding Precio}" />

                    <DataGridTextColumn Header="Stock"
                                        Binding="{Binding Stock}" />
                    
                    <DataGridTextColumn Header="Stock Mínimo"
                                        Binding="{Binding StockMinimo}" />
                    
                    <DataGridTextColumn Header="Categoría"
                                        Binding="{Binding Categoria}" />
                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>

    </Grid>
    
</UserControl>
